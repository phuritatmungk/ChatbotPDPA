# Local LLM (llama-server). Leave MODEL/OPENAI_API_KEY as placeholders
# if you're using the local server defined in llm.bat.
MODEL=your_model_name
OPENAI_API_KEY=your_openai_api_key

# Qdrant Cloud — primary collection
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Qdrant Cloud — secondary collection (optional)
QDRANT_URL2=https://your-second-cluster.qdrant.io
QDRANT_API_KEY2=your_second_qdrant_api_key

# Typhoon OCR (optional, for OCR-based ingestion)
TYPHOON_OCR_API_KEY=your_typhoon_ocr_key

# Embedding model used for both ingestion and retrieval
RAG_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
